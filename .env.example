# =============================================================================
# МойМагазин — переменные окружения (Vercel: Settings → Environment Variables)
# Скопируйте в .env.local для локальной разработки
# =============================================================================

# --- Wildberries / каталог ---

# ID продавца Wildberries (Райзз)
WB_SUPPLIER_ID=4277037

# Кэш API каталога в миллисекундах (по умолчанию 1 час)
WB_CACHE_TTL_MS=3600000

# Официальный API WB — полный каталог, цены и остатки
# Создать: seller.wildberries.ru → Настройки → Доступ к API
# Нужны категории: Контент, Цены и скидки, Маркетплейс
WB_API_TOKEN=

# Юнит-экономика → Google Таблица (npm run sync:unit)
# GOOGLE_SHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_PATH=

# ID склада продавца (опционально; если не задан — первый склад из API)
WB_WAREHOUSE_ID=

# Секрет для cron-синхронизации каталога (/api/cron/sync)
CRON_SECRET=

# --- База данных ---

# Postgres (Vercel Storage → Postgres → подключить к проекту)
# После подключения Vercel создаёт POSTGRES_URL автоматически
POSTGRES_URL=

# --- Авторизация и админка ---

# Секрет для JWT-сессий (обязательно в production — случайная длинная строка)
JWT_SECRET=change-me-to-random-string

# Секрет для ручного управления ценами/остатками через /api/admin/product-overrides
ADMIN_SECRET=

# --- Сайт и SEO ---

# Публичный URL сайта (письма, sitemap, JSON-LD)
SITE_URL=https://moi-magazin.vercel.app

# То же для фронтенда (meta, JSON-LD на карточке товара)
VITE_SITE_URL=https://moi-magazin.vercel.app

# Переопределение URL API каталога (обычно не нужно)
# VITE_PRODUCTS_API=/api/products

# --- Email (Resend) ---

# API-ключ Resend — подтверждение заказа, сброс пароля
RESEND_API_KEY=

# Адрес отправителя (домен должен быть верифицирован в Resend)
EMAIL_FROM=МойМагазин <orders@moi-magazin.ru>

# --- Оплата (ЮKassa) ---

# Shop ID и секретный ключ из личного кабинета ЮKassa
# Без них оплата картой создаёт заказ, но без редиректа на оплату
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Аналитика ---

# ID счётчика Яндекс.Метрики (только цифры)
VITE_YANDEX_METRIKA_ID=

# --- Карты и адреса ---

# Яндекс.Карты — статическая карта ПВЗ (опционально; без ключа — iframe)
YANDEX_MAPS_API_KEY=
# JavaScript API 3.0 — карта в виджете СДЭК (VITE_ попадает в клиентский бандл)
VITE_YANDEX_MAPS_API_KEY=
# HTTP Геокодер — поиск адресов внутри виджета СДЭК (отдельный ключ в кабинете Яндекса)
VITE_YANDEX_GEOCODER_API_KEY=
# Для обоих ключей в «Ограничение по HTTP Referer» укажите домен без https://,
# например: moi-magazin.vercel.app

# DaData — подсказки адреса (опционально)
DADATA_API_KEY=

# --- СДЭК (виджет доставки 3.0) ---

# Идентификатор аккаунта и пароль из ЛК СДЭК → Интеграция → Создать ключ
CDEK_ACCOUNT=
CDEK_SECURE_PASSWORD=
# Тестовый API (опционально): https://api.edu.cdek.ru/v2
# CDEK_API_URL=https://api.edu.cdek.ru/v2

# --- AI-черновики отзывов WB (unit-calc) ---

# YandexGPT — рекомендуется из РФ (console.yandex.cloud → каталог → Foundation Models → API-ключ)
YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
# YANDEX_CLOUD_API_KEY=   # альтернативное имя для YANDEX_GPT_API_KEY
# YANDEX_GPT_MODEL=yandexgpt-lite

# OpenAI — опционально, если есть доступ к openai.com
# OPENAI_API_KEY=
