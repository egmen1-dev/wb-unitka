{
  "buildCommand": "node node_modules/vite/bin/vite.js build --config wb-unit-calc/vite.config.js",
  "outputDirectory": "wb-unit-calc/dist",
  "framework": null,
  "functions": {
    "api/unit-calc/sync.js": {
      "maxDuration": 300
    },
    "api/unit-calc/supplier-price.js": {
      "maxDuration": 60
    },
    "api/unit-calc/feedbacks.js": {
      "maxDuration": 60
    },
    "api/unit-calc/feedback-draft.js": {
      "maxDuration": 60
    },
    "api/unit-calc/feedbacks-check.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
